{
  "manifest_version": 3,
  "name": "Media Hotkeys",
  "description": "Adds hotkeys to control HTML video or audio on any webpage",
  "permissions": ["storage", "activeTab"],
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    },
    "default_title": "Media Hotkeys",
    "default_popup": "quick-settings-popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["player-bridge.js"],
      "all_frames": true,
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "advanced-settings-page.html",
    "open_in_tab": true
  }
}
