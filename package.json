{
  "name": "media-hotkeys",
  "version": "0.1.0",
  "description": "A browser extension that adds hotkeys to control HTML video or audio on any webpage",
  "author": "Jared Cook",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build.js",
    "build:chrome": "node scripts/build.js --browser chrome",
    "build:firefox": "node scripts/build.js --browser firefox",
    "build:safari": "node scripts/build.js --browser safari",
    "package": "node scripts/package.js",
    "package:chrome": "node scripts/package.js --browser chrome",
    "package:firefox": "node scripts/package.js --browser firefox",
    "package:safari": "node scripts/package.js --browser safari",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint src/ tests/",
    "format": "prettier --write src/ tests/",
    "format:check": "prettier --check src/ tests/",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.42.0",
    "@types/chrome": "^0.0.268",
    "@types/firefox-webext-browser": "^120.0.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.58.0",
    "vite": "^5.2.0",
    "vitest": "^1.4.0"
  },
  "dependencies": {
    "webextension-polyfill": "^0.10.0"
  },
  "bugs": {
    "url": "https://github.com/jaredbcook/media-hotkeys/issues"
  },
  "homepage": "https://github.com/jaredbcook/media-hotkeys"
}
