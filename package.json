{
  "name": "media-hotkeys",
  "version": "0.1.0",
  "description": "A browser extension that adds hotkeys to control HTML video or audio on any webpage",
  "author": "Jared Cook",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsx scripts/build.ts",
    "build:chrome": "tsx scripts/build.ts --browser chrome",
    "build:edge": "tsx scripts/build.ts --browser edge",
    "build:firefox": "tsx scripts/build.ts --browser firefox",
    "package": "tsx scripts/package.ts",
    "package:chrome": "tsx scripts/package.ts --browser chrome",
    "package:edge": "tsx scripts/package.ts --browser edge",
    "package:firefox": "tsx scripts/package.ts --browser firefox",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.tools.json --noEmit",
    "safari:convert": "tsx scripts/safari-convert.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint src/ scripts/ tests/ eslint.config.js vite.config.ts vitest.config.ts playwright.config.ts",
    "format": "prettier --write src/ scripts/ tests/ eslint.config.js vite.config.ts vitest.config.ts playwright.config.ts *.json *.md",
    "format:check": "prettier --check src/ scripts/ tests/ eslint.config.js vite.config.ts vitest.config.ts playwright.config.ts *.json *.md",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.42.0",
    "@types/chrome": "^0.0.268",
    "@types/archiver": "^6.0.3",
    "@types/firefox-webext-browser": "^120.0.0",
    "@types/node": "^20.0.0",
    "@types/webextension-polyfill": "^0.12.3",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "archiver": "^7.0.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "tsx": "^4.20.6",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.58.0",
    "vite": "^5.2.0",
    "vitest": "^1.4.0"
  },
  "dependencies": {
    "webextension-polyfill": "^0.10.0"
  },
  "bugs": {
    "url": "https://github.com/jaredbcook/media-hotkeys/issues"
  },
  "homepage": "https://github.com/jaredbcook/media-hotkeys"
}
